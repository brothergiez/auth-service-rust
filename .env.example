# Process role: api | worker | cron
APP_MODE=api

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# Database name (collections: users)
DATABASE_NAME=auth_service

# HS256 secret — use at least 32 random bytes in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Access token lifetime in seconds (default: 3600)
JWT_EXPIRATION_SECS=3600

# HTTP bind (defaults: 0.0.0.0:3000)
HOST=0.0.0.0
PORT=3000

# Optional: RUST_LOG=info,auth_service=debug
RUST_LOG=info

# --- worker mode (Kafka consumer) ---
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=auth-events
# KAFKA_GROUP_ID=auth-service-worker

# --- cron mode ---
# Six-field cron: sec min hour day month weekday (tokio-cron-scheduler)
# CRON_SCHEDULE=0 * * * * *
