# =============================================================================
#  auth-service — environment template
#
#  How to use: copy to `.env` and edit.
#    cp .env.example .env
#
#  Only the block that matches your APP_MODE (and database choice) needs to
#  be correct. You can leave other sections commented out.
# =============================================================================


# -----------------------------------------------------------------------------
#  1) Process role — which binary behavior to run
# -----------------------------------------------------------------------------
#  Values:  api  |  worker  |  cron
#
#    api     → HTTP server (auth routes + Swagger)
#    worker  → Kafka consumer
#    cron    → scheduled jobs (tokio-cron-scheduler)
APP_MODE=api


# =============================================================================
#  2) API mode — HTTP + where USER records are stored
# =============================================================================
#
#  DATABASE_DRIVER picks ONE backend for the `users` table/collection only.
#  Allowed values:  mongo  |  mysql     (if unset, defaults to mongo)
#
#  ── Use EITHER the Mongo block OR the MySQL block below, not both. ──

DATABASE_DRIVER=mongo

# . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .
#  Option A — MongoDB for users
# . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .
#  Required when DATABASE_DRIVER is mongo (or omitted).
#  DATABASE_NAME = logical Mongo database name (collections live inside it).

MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=auth_service

# . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .
#  Option B — MySQL for users
# . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .
#  1) Set:   DATABASE_DRIVER=mysql
#  2) Set:   DATABASE_URL   (sqlx format; database must already exist, empty is fine)
#  3) On first API start, SQL files in `migrations/` are applied automatically.
#
# DATABASE_DRIVER=mysql
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME


# -----------------------------------------------------------------------------
#  3) API mode — auth + HTTP listen (always relevant when APP_MODE=api)
# -----------------------------------------------------------------------------
#  JWT_SECRET: min 32 characters (HS256). Generate a long random string in prod.

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

#  Access token lifetime in seconds (default 3600 if omitted).
JWT_EXPIRATION_SECS=3600

#  HTTP bind address (defaults shown).
HOST=0.0.0.0
PORT=3000


# -----------------------------------------------------------------------------
#  Optional — Redis (only when APP_MODE=api)
# -----------------------------------------------------------------------------
#  If REDIS_URL is set to a non-empty value, the server opens an async
#  connection manager on startup and exposes it as `AppState.redis` (Some).
#  If unset or blank: Redis is not used (`AppState.redis` is None).
#
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=rediss://user:password@example.com:6380


# -----------------------------------------------------------------------------
#  4) Shared — logging (any mode)
# -----------------------------------------------------------------------------
#  Examples: info   |   debug   |   auth_service=debug
RUST_LOG=info


# =============================================================================
#  5) Worker mode — only when APP_MODE=worker
# =============================================================================

# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=auth-events
# KAFKA_GROUP_ID=auth-service-worker


# =============================================================================
#  6) Cron mode — only when APP_MODE=cron
# =============================================================================
#  Six fields:  second  minute  hour  day-of-month  month  day-of-week
#  (see tokio-cron-scheduler docs)

# CRON_SCHEDULE=0 * * * * *
